# 当前为纯静态站点（无运行时后端）。
# 如需在前端中启用自定义公开变量，请以 VITE_ 开头自行新增。
# Decap OAuth（Vercel Function）示例：
# ORIGIN="http://localhost:5173"
# COMPLETE_URL="http://localhost:5173/api/oauth/callback"
# ADMIN_PANEL_URL="http://localhost:5173/admin/"
# OAUTH_PROVIDER="github"
# OAUTH_CLIENT_ID=""
# OAUTH_CLIENT_SECRET=""
# OAUTH_SCOPES="repo,user,read:org"
